---
import '../styles/global.css';
import { SITE_NAME, SITE_TAGLINE, base } from '../lib/site';

interface Props {
  title?: string;
  description?: string;
}
const { title, description = SITE_TAGLINE } = Astro.props;
const fullTitle = title ? `${title} · ${SITE_NAME}` : `${SITE_NAME}. ${SITE_TAGLINE}`;

const nav = [
  { href: base, label: 'Home' },
  { href: base + 'dictionary', label: 'Dictionary' },
  { href: base + 'skill', label: 'Skill' },
  { href: base + 'credits', label: 'Colophon' },
];
const here = Astro.url.pathname.replace(/\/+$/, '');
const isActive = (href: string) => here === href.replace(/\/+$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <link rel="canonical" href={Astro.url.href} />
  </head>
  <body
    class="min-h-screen bg-white text-zinc-900 antialiased dark:bg-zinc-950 dark:text-zinc-100"
  >
    <header
      class="sticky top-0 z-20 border-b border-zinc-200 bg-white/90 backdrop-blur dark:border-zinc-800 dark:bg-zinc-950/90"
    >
      <nav class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-3">
        <a href={base} class="font-semibold tracking-tight hover:opacity-70">
          {SITE_NAME}
        </a>
        <ul class="flex items-center gap-4 text-sm">
          {
            nav.slice(1).map((item) => (
              <li>
                <a
                  href={item.href}
                  class={
                    'hover:opacity-70 ' +
                    (isActive(item.href)
                      ? 'font-medium text-zinc-900 underline underline-offset-4 dark:text-zinc-100'
                      : 'text-zinc-500 dark:text-zinc-400')
                  }
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-zinc-200 dark:border-zinc-800">
      <div
        class="mx-auto max-w-5xl px-4 py-8 text-sm text-zinc-500 dark:text-zinc-400"
      >
        <p>
          Built by Chris Northfield. It builds on work by Matt Pocock, Andrej Karpathy,
          and the llms.txt convention. See the <a
            class="underline underline-offset-2 hover:opacity-70"
            href={base + 'credits'}>colophon</a
          >.
        </p>
        <p class="mt-2">
          No signup, no tracking. A static site that serves clean markdown to coding agents.
        </p>
      </div>
    </footer>
  </body>
</html>
